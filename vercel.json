{
  "installCommand": "cd itrak-project/itrak-project && pnpm install",
  "buildCommand": "cd itrak-project/itrak-project && pnpm exec vite build",
  "outputDirectory": "itrak-project/itrak-project/dist/client",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
